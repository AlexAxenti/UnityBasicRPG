      questEventTargetId: 
      questEventAmount: 1
      questConditionType: 0
      conditionQuestId: 
      requiredStepIndex: -1
  - nodeId: Shopping
    speakerName: Jered
    dialogueText: 'Here''s my wares:'
    choices:
    - choiceText: Thank you!
      nextNodeId: 
      endsDialogue: 1
      actionType: 0
      questId: 
      questEventType: 0
      questEventTargetId: 
      questEventAmount: 1
      questConditionType: 0
      conditionQuestId: 
      requiredStepIndex: -1
  - nodeId: start_training
    speakerName: Jered
    dialogueText: Of course I can, you can take my bat and head off to the forest!
