      endsDialogue: 1
      actionType: 0
      questId: 
      questEventType: 0
      questEventTargetId: 
      questEventAmount: 1
      questConditionType: 0
      conditionQuestId: 
      requiredStepIndex: -1
  - nodeId: pick_up_bat_command
    speakerName: Jered
    dialogueText: That's the spirit! Grab my bat beside me
    choices:
    - choiceText: (end)
      nextNodeId: 
      endsDialogue: 1
      actionType: 0
      questId: 
      questEventType: 2
      questEventTargetId: 
      questEventAmount: 0
      questConditionType: 0
      conditionQuestId: 
