  startingNodeId: Start
  nodes:
  - nodeId: Start
    speakerName: Jered
    dialogueText: 'Hello traveler, welcome to our village!

      I''m Jered the
      local salesman!'
    choices:
    - choiceText: What do you have for sale?
      nextNodeId: Shopping
      endsDialogue: 0
      actionType: 1
      questId: 
      questEventType: 0
      questEventTargetId: 
      questEventAmount: 1
      questConditionType: 0
      conditionQuestId: 
      requiredStepIndex: -1
    - choiceText: Can you help me defeat those goblins in the forest?
