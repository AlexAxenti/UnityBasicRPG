      endsDialogue: 0
      actionType: 0
      questId: 
      questEventType: 0
      questEventTargetId: 
      questEventAmount: 1
      questConditionType: 1
      conditionQuestId: jered_training
      requiredStepIndex: -1
    - choiceText: I picked up the bat.
      nextNodeId: kill_goblins_command
      endsDialogue: 0
      actionType: 3
      questId: jered_training
      questEventType: 2
      questEventTargetId: return_to_jared_1_obj
      questEventAmount: 1
      questConditionType: 2
      conditionQuestId: jered_training
      requiredStepIndex: 1
    - choiceText: I've killed 3 goblins.
